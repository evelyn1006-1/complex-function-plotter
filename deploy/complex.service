[Unit]
Description=Complex Function Plotter
After=network.target

[Service]
User=evelyn
Group=www-data
WorkingDirectory=/home/evelyn/complex
Environment="PATH=/usr/local/bin:/usr/local/python-3.14.4/bin:/usr/bin"
EnvironmentFile=/home/evelyn/complex/.env
ExecStart=/usr/local/bin/gunicorn \
  --config /home/evelyn/complex/gunicorn.conf.py \
  app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
